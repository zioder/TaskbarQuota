<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TaskbarQuota.Controls.WidgetSummary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" Background="Transparent" Padding="6,3" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="4"/>
        </Grid.RenderTransform>
        <Grid x:Name="Panel" ColumnSpacing="6" RowSpacing="3"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="17"/>
                <RowDefinition Height="17"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="IconColumn" Width="30"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="BadgeHost" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                  Width="30" Height="30"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox x:Name="BadgeGlyphBox" Width="20" Height="20" Visibility="Collapsed"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="100" Height="100">
                        <Path x:Name="BadgeGlyph"/>
                    </Canvas>
                </Viewbox>
                <TextBlock x:Name="BadgeText" Text="?" FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
