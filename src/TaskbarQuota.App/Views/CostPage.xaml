<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TaskbarQuota.Views.CostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TaskbarQuota.Controls"
    xmlns:vm="using:TaskbarQuota.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title + info + share -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Cost" Style="{StaticResource TitleTextBlockStyle}"/>
                <Button x:Name="InfoButton" Background="Transparent" BorderThickness="0"
                        Padding="4" VerticalAlignment="Center"
                        ToolTipService.ToolTip="What is this?">
                    <FontIcon Glyph="&#xE946;" FontSize="16"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <Button.Flyout>
                        <Flyout>
                            <TextBlock MaxWidth="300" TextWrapping="Wrap"
                                       Text="What these tokens would cost at public pay-as-you-go API rates — regardless of your (subsidized) subscription. Shows how much value each plan is really delivering."/>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <Button x:Name="ShareButton" Click="OnShareClick"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" Padding="8"
                    ToolTipService.ToolTip="Share as image">
                <FontIcon Glyph="&#xE72D;" FontSize="18"/>
            </Button>
        </Grid>

        <!-- Range selector -->
        <muxc:SelectorBar x:Name="RangeBar" Grid.Row="1" SelectionChanged="OnRangeChanged">
            <muxc:SelectorBarItem Text="Today" Tag="Today" IsSelected="True"/>
            <muxc:SelectorBarItem Text="Yesterday" Tag="Yesterday"/>
            <muxc:SelectorBarItem Text="7 Days" Tag="Last7Days"/>
            <muxc:SelectorBarItem Text="30 Days" Tag="Last30Days"/>
        </muxc:SelectorBar>

        <!-- Shareable card -->
        <Border x:Name="ShareCard" Grid.Row="2" VerticalAlignment="Top"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="12" Padding="24">
            <Grid>
                <!-- Loading -->
                <muxc:ProgressRing x:Name="Spinner" IsActive="False"
                                   Width="32" Height="32"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Empty -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed" Spacing="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE9D2;" FontSize="28"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="No usage in this window"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Content: donut + legend, side by side on wide, stacked on narrow -->
                <Grid x:Name="Content" ColumnSpacing="28" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <controls:CostDonut x:Name="Donut" Grid.Column="0"
                                        Width="200" Height="200"
                                        Segments="{x:Bind ViewModel.Segments, Mode=OneWay}"
                                        CenterText="{x:Bind ViewModel.TotalText, Mode=OneWay}"
                                        CenterSubtitle="API value"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="12">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CostSegmentViewModel">
                                    <Grid Padding="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="12" Height="12"
                                                 VerticalAlignment="Center"
                                                 Fill="{x:Bind Brush}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind CostText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{x:Bind ViewModel.UnpricedNote, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.UnpricedNoteVisibility, Mode=OneWay}"
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
